APP_NAME=Harness Framework API
APP_VERSION=0.1.0
APP_ENV=local
API_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

DATABASE_URL=postgresql+psycopg://harness:harness@127.0.0.1:5432/harness
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

WEBHOOK_SECRET=dev-webhook-secret
NANO_BANANA_API_KEY=replace-me
BLOG_API_BASE_URL=https://blog.example.com/api
BLOG_API_TOKEN=replace-me

OBSERVABILITY_SLOW_REQUEST_MS=1500
